rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Função helper para verificar se o usuário está logado
    function isAuthenticated() {
      return request.auth != null;
    }

    // Função helper para verificar se o usuário é admin via Custom Claim JWT
    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    // Regras para Coleção de Usuários
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin(); // Apenas admin pode criar/editar usuários via painel
      
      // Regras para Progresso do Usuário (Subcollection)
      match /progress/{cardId} {
        // Usuário pode ler/escrever apenas seu próprio progresso. Admin pode ler de todos.
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      }
    }

    // Regras para Coleção de Flashcards
    match /flashcards/{cardId} {
      // Qualquer um autenticado pode ler flashcards publicados. (Ou leitura pública se desejar)
      allow read: if isAuthenticated() && resource.data.published == true;
      // Admin pode ler todos (mesmo drafts) e fazer qualquer modificação
      allow read, write: if isAdmin();
    }

    // Sistema de Configurações
    match /system/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
