    "@typescript-eslint/parser": "^7.11.0",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.0",
    "firebase-admin": "^12.0.0",
    "firebase-tools": "^13.3.0",
    "husky": "^9.0.11",
    "jsdom": "^29.1.1",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
