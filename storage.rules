rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Função helper para verificar Custom Claim
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    match /{allPaths=**} {
      // Qualquer usuário logado pode visualizar imagens (arquivos médicos)
      allow read: if request.auth != null;
      // Somente administradores podem fazer upload/delete de mídias
      allow write: if isAdmin();
    }
  }
}
